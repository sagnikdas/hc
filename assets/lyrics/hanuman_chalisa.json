{
  "title": "Hanuman Chalisa",
  "totalDurationSeconds": 586,
  "lines": [
    { "startSeconds": 2.75,  "text": "॥ दोहा ॥",                                              "en": "|| Doha ||" },
    { "startSeconds": 2.75,  "text": "श्रीगुरु चरन सरोज रज, निज मनु मुकुरु सुधारि।",         "en": "Shri Guru Charan Saroj Raj, Nij Man Mukur Sudhari," },
    { "startSeconds": 14.45, "text": "बरनउँ रघुबर बिमल जसु, जो दायकु फल चारि॥",            "en": "Baranau Raghubar Bimal Jasu, Jo Dayaku Phal Chari." },
    { "startSeconds": 25.18, "text": "बुद्धिहीन तनु जानिके, सुमिरौं पवन-कुमार।",            "en": "Buddhihin Tanu Jaanike, Sumiron Pawan Kumar," },
    { "startSeconds": 36.59, "text": "बल बुद्धि बिद्या देहु मोहिं, हरहु कलेस बिकार॥",      "en": "Bal Buddhi Vidya Dehu Mohi, Harahu Kales Bikar." },

    { "startSeconds": 56.57, "text": "॥ चौपाई ॥",                                             "en": "|| Chaupai ||" },
    { "startSeconds": 56.57, "text": "जय हनुमान ज्ञान गुन सागर।",                            "en": "Jai Hanuman Gyan Gun Sagar," },
    { "startSeconds": 62.27, "text": "जय कपीस तिहुँ लोक उजागर॥ १॥",                         "en": "Jai Kapees Tihu Lok Ujagar. (1)" },
    { "startSeconds": 67.60, "text": "राम दूत अतुलित बल धामा।",                              "en": "Ram Doot Atoolit Bal Dhama," },
    { "startSeconds": 72.95, "text": "अञ्जनि-पुत्र पवनसुत नामा॥ २॥",                        "en": "Anjani Putra Pavanasoota Nama. (2)" },

    { "startSeconds": 83.51, "text": "महाबीर बिक्रम बजरंगी।",                                "en": "Mahabeer Bikram Bajrangi," },
    { "startSeconds": 89.13, "text": "कुमति निवार सुमति के संगी॥ ३॥",                        "en": "Kumati Niwar Sumati Ke Sangi. (3)" },
    { "startSeconds": 94.21, "text": "कञ्चन बरन बिराज सुबेसा।",                              "en": "Kanchan Baran Biraj Subesa," },
    { "startSeconds": 99.56, "text": "कानन कुण्डल कुञ्चित केसा॥ ४॥",                        "en": "Kanan Kundal Kunchit Kesa. (4)" },

    { "startSeconds": 104.91, "text": "हाथ बज्र औ ध्वजा बिराजै।",                           "en": "Haath Bajra Au Dhwaja Birajai," },
    { "startSeconds": 110.14, "text": "काँधे मूँज जनेऊ साजै॥ ५॥",                           "en": "Kaandhe Moonj Janeu Sajai. (5)" },
    { "startSeconds": 115.46, "text": "संकर सुवन केसरीनन्दन।",                               "en": "Shankar Suvan Kesarinandan," },
    { "startSeconds": 120.65, "text": "तेज प्रताप महा जग बन्दन॥ ६॥",                        "en": "Tej Pratap Maha Jag Bandan. (6)" },

    { "startSeconds": 131.16, "text": "विद्यावान गुनी अति चातुर।",                           "en": "Vidyavaan Guni Ati Chatur," },
    { "startSeconds": 136.62, "text": "राम काज करिबे को आतुर॥ ७॥",                          "en": "Ram Kaaj Karibe Ko Atur. (7)" },
    { "startSeconds": 141.90, "text": "प्रभु चरित्र सुनिबे को रसिया।",                       "en": "Prabhu Charitra Sunibe Ko Rasiya," },
    { "startSeconds": 147.21, "text": "राम लखन सीता मन बसिया॥ ८॥",                          "en": "Ram Lakhan Sita Man Basiya. (8)" },

    { "startSeconds": 152.52, "text": "सूक्ष्म रूप धरि सियहिं दिखावा।",                     "en": "Sukshma Roop Dhari Siyahi Dikhawa," },
    { "startSeconds": 157.77, "text": "बिकट रूप धरि लंक जरावा॥ ९॥",                        "en": "Bikat Roop Dhari Lanka Jarawa. (9)" },
    { "startSeconds": 163.05, "text": "भीम रूप धरि असुर सँहारे।",                           "en": "Bheem Roop Dhari Asur Sanhare," },
    { "startSeconds": 168.33, "text": "रामचन्द्र के काज सँवारे॥ १०॥",                       "en": "Ramchandra Ke Kaaj Sanware. (10)" },

    { "startSeconds": 178.62, "text": "लाय सञ्जीवन लखन जियाये।",                            "en": "Laay Sanjeevan Lakhan Jiyaye," },
    { "startSeconds": 184.25, "text": "श्री रघुबीर हरषि उर लाये॥ ११॥",                      "en": "Shri Raghubeer Harashi Ur Laaye. (11)" },
    { "startSeconds": 189.53, "text": "रघुपति कीन्ही बहुत बड़ाई।",                          "en": "Raghupati Kinhi Bahut Badaai," },
    { "startSeconds": 194.76, "text": "तुम मम प्रिय भरतहि सम भाई॥ १२॥",                    "en": "Tum Mam Priya Bharatahi Sam Bhai. (12)" },

    { "startSeconds": 200.03, "text": "सहस बदन तुम्हरो जस गावैं।",                          "en": "Sahas Badan Tumharo Jas Gavain," },
    { "startSeconds": 205.20, "text": "अस कहि श्रीपति कण्ठ लगावैं॥ १३॥",                   "en": "As Kahi Shripati Kanth Lagavain. (13)" },
    { "startSeconds": 210.52, "text": "सनकादिक ब्रह्मादि मुनीसा।",                          "en": "Sankaadik Brahmadi Munisa," },
    { "startSeconds": 215.91, "text": "नारद-सारद सहित अहीसा॥ १४॥",                         "en": "Narad Saarad Sahit Ahisa. (14)" },

    { "startSeconds": 226.26, "text": "जम कुबेर दिगपाल जहाँ ते।",                           "en": "Jam Kuber Digpal Jahan Te," },
    { "startSeconds": 231.82, "text": "कबि कोबिद कहि सके कहाँ ते॥ १५॥",                    "en": "Kabi Kobid Kahi Sake Kahan Te. (15)" },
    { "startSeconds": 237.12, "text": "तुम उपकार सुग्रीवहिं कीन्हा।",                       "en": "Tum Upkar Sugreevahi Kinha," },
    { "startSeconds": 242.39, "text": "राम मिलाय राजपद दीन्हा॥ १६॥",                       "en": "Ram Milaay Rajpad Dinha. (16)" },

    { "startSeconds": 247.57, "text": "तुम्हरो मन्त्र बिभीषन माना।",                        "en": "Tumharo Mantra Bibhishan Maana," },
    { "startSeconds": 252.88, "text": "लंकेस्वर भए सब जग जाना॥ १७॥",                       "en": "Lankeshwar Bhaye Sab Jag Jaana. (17)" },
    { "startSeconds": 258.30, "text": "जुग सहस्र जोजन पर भानू।",                            "en": "Jug Sahastra Jojan Par Bhanu," },
    { "startSeconds": 263.57, "text": "लील्यो ताहि मधुर फल जानू॥ १८॥",                     "en": "Lilyo Taahi Madhur Phal Jaanu. (18)" },

    { "startSeconds": 274.06, "text": "प्रभु मुद्रिका मेलि मुख माहीं।",                     "en": "Prabhu Mudrika Meli Mukh Mahi," },
    { "startSeconds": 279.65, "text": "जलधि लाँघि गये अचरज नाहीं॥ १९॥",                    "en": "Jaladhi Laanghi Gaye Acharaj Nahi. (19)" },
    { "startSeconds": 284.87, "text": "दुर्गम काज जगत के जेते।",                            "en": "Durgam Kaaj Jagat Ke Jete," },
    { "startSeconds": 290.05, "text": "सुगम अनुग्रह तुम्हरे तेते॥ २०॥",                    "en": "Sugam Anugraha Tumhare Tete. (20)" },

    { "startSeconds": 295.34, "text": "राम दुआरे तुम रखवारे।",                              "en": "Ram Duaare Tum Rakhwaare," },
    { "startSeconds": 300.67, "text": "होत न आज्ञा बिनु पैसारे॥ २१॥",                      "en": "Hot Na Agya Binu Paisare. (21)" },
    { "startSeconds": 306.03, "text": "सब सुख लहैं तुम्हारी सरना।",                        "en": "Sab Sukh Lahe Tumhari Sarna," },
    { "startSeconds": 311.26, "text": "तुम रक्षक काहू को डरना॥ २२॥",                       "en": "Tum Rakshak Kahu Ko Darna. (22)" },

    { "startSeconds": 321.76, "text": "आपन तेज सम्हारो आपै।",                              "en": "Aapan Tej Samharo Aapai," },
    { "startSeconds": 327.28, "text": "तीनों लोक हाँक तें काँपै॥ २३॥",                     "en": "Teeno Lok Haank Te Kaampai. (23)" },
    { "startSeconds": 332.65, "text": "भूत पिसाच निकट नहिं आवै।",                          "en": "Bhoot Pisaach Nikat Nahi Aavai," },
    { "startSeconds": 337.62, "text": "महाबीर जब नाम सुनावै॥ २४॥",                         "en": "Mahabeer Jab Naam Sunavai. (24)" },

    { "startSeconds": 343.08, "text": "नासै रोग हरै सब पीरा।",                              "en": "Naasai Rog Harai Sab Pira," },
    { "startSeconds": 348.36, "text": "जपत निरन्तर हनुमत बीरा॥ २५॥",                       "en": "Japat Nirantar Hanumat Bira. (25)" },
    { "startSeconds": 353.66, "text": "संकट तें हनुमान छुड़ावै।",                           "en": "Sankat Te Hanuman Chhuravai," },
    { "startSeconds": 359.08, "text": "मन क्रम बचन ध्यान जो लावै॥ २६॥",                   "en": "Man Kram Bachan Dhyan Jo Lavai. (26)" },

    { "startSeconds": 369.43, "text": "सब पर राम तपस्वी राजा।",                            "en": "Sab Par Ram Tapasvi Raja," },
    { "startSeconds": 374.98, "text": "तिनके काज सकल तुम साजा॥ २७॥",                       "en": "Tinke Kaaj Sakal Tum Saaja. (27)" },
    { "startSeconds": 380.15, "text": "और मनोरथ जो कोई लावै।",                             "en": "Aur Manorath Jo Koi Lavai," },
    { "startSeconds": 385.31, "text": "सोई अमित जीवन फल पावै॥ २८॥",                       "en": "Soi Amit Jeevan Phal Pavai. (28)" },

    { "startSeconds": 390.77, "text": "चारों जुग परताप तुम्हारा।",                          "en": "Charon Jug Partap Tumhara," },
    { "startSeconds": 396.15, "text": "है परसिद्ध जगत उजियारा॥ २९॥",                       "en": "Hai Parsiddh Jagat Ujiyara. (29)" },
    { "startSeconds": 401.36, "text": "साधु-सन्त के तुम रखवारे।",                          "en": "Sadhu Sant Ke Tum Rakhware," },
    { "startSeconds": 406.74, "text": "असुर निकन्दन राम दुलारे॥ ३०॥",                      "en": "Asur Nikandan Ram Dulare. (30)" },

    { "startSeconds": 416.95, "text": "अष्टसिद्धि नव निधि के दाता।",                       "en": "Ashta Siddhi Nava Nidhi Ke Daata," },
    { "startSeconds": 422.37, "text": "अस बर दीन्ह जानकी माता॥ ३१॥",                       "en": "As Bar Dinh Janaki Mata. (31)" },
    { "startSeconds": 427.58, "text": "राम रसायन तुम्हरे पासा।",                            "en": "Ram Rasayan Tumhare Paasa," },
    { "startSeconds": 432.72, "text": "सदा रहो रघुपति के दासा॥ ३२॥",                       "en": "Sada Raho Raghupati Ke Dasa. (32)" },

    { "startSeconds": 438.11, "text": "तुम्हरे भजन राम को पावै।",                           "en": "Tumhare Bhajan Ram Ko Pavai," },
    { "startSeconds": 443.47, "text": "जनम-जनम के दुख बिसरावै॥ ३३॥",                       "en": "Janam Janam Ke Dukh Bisravai. (33)" },
    { "startSeconds": 448.79, "text": "अन्त काल रघुबर पुर जाई।",                           "en": "Ant Kaal Raghubar Pur Jaai," },
    { "startSeconds": 454.02, "text": "जहाँ जन्म हरि-भक्त कहाई॥ ३४॥",                     "en": "Jahan Janam Hari Bhakt Kahai. (34)" },

    { "startSeconds": 464.23, "text": "और देवता चित्त न धरई।",                             "en": "Aur Devata Chitt Na Dharai," },
    { "startSeconds": 469.73, "text": "हनुमत सेई सर्ब सुख करई॥ ३५॥",                      "en": "Hanumat Sei Sarb Sukh Karai. (35)" },
    { "startSeconds": 474.91, "text": "संकट कटै मिटै सब पीरा।",                            "en": "Sankat Katai Mitai Sab Pira," },
    { "startSeconds": 480.10, "text": "जो सुमिरै हनुमत बलबीरा॥ ३६॥",                      "en": "Jo Sumirai Hanumat Balbira. (36)" },

    { "startSeconds": 485.54, "text": "जय जय जय हनुमान गोसाईं।",                           "en": "Jai Jai Jai Hanuman Gosain," },
    { "startSeconds": 490.69, "text": "कृपा करहु गुरुदेव की नाईं॥ ३७॥",                    "en": "Kripa Karahu Gurudev Ki Naain. (37)" },
    { "startSeconds": 496.05, "text": "जो सत बार पाठ कर कोई।",                             "en": "Jo Sat Baar Path Kar Koi," },
    { "startSeconds": 501.20, "text": "छूटहि बन्दि महा सुख होई॥ ३८॥",                     "en": "Chutahi Bandi Maha Sukh Hoi. (38)" },

    { "startSeconds": 511.48, "text": "जो यह पढ़ै हनुमान चालीसा।",                         "en": "Jo Yah Padhai Hanuman Chalisa," },
    { "startSeconds": 517.07, "text": "होय सिद्धि साखी गौरीसा॥ ३९॥",                      "en": "Hoy Siddhi Sakhi Gaurisa. (39)" },
    { "startSeconds": 522.32, "text": "तुलसीदास सदा हरि चेरा।",                            "en": "Tulsidas Sada Hari Chera," },
    { "startSeconds": 527.38, "text": "कीजै नाथ हृदय मँह डेरा॥ ४०॥",                      "en": "Kijai Nath Hriday Mah Dera. (40)" },

    { "startSeconds": 540.93, "text": "॥ दोहा ॥",                                            "en": "|| Doha ||" },
    { "startSeconds": 549.48, "text": "पवनतनय संकट हरन, मंगल मूरति रूप।",                  "en": "Pavanataney Sankat Haran, Mangal Moorti Roop," },
    { "startSeconds": 557.38, "text": "राम लखन सीता सहित, हृदय बसहु सुर भूप॥",            "en": "Ram Lakhan Sita Sahit, Hriday Basahu Sur Bhoop." }
  ]
}
