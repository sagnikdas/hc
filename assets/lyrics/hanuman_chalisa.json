{
  "title": "Hanuman Chalisa",
  "totalDurationSeconds": 586,
  "lines": [
    { "startSeconds": 2.75, "text": "॥ दोहा ॥" },
    { "startSeconds": 2.75, "text": "श्रीगुरु चरन सरोज रज, निज मनु मुकुरु सुधारि।" },
    { "startSeconds": 14.45, "text": "बरनउँ रघुबर बिमल जसु, जो दायकु फल चारि॥" },
    { "startSeconds": 25.18, "text": "बुद्धिहीन तनु जानिके, सुमिरौं पवन-कुमार।" },
    { "startSeconds": 36.59, "text": "बल बुद्धि बिद्या देहु मोहिं, हरहु कलेस बिकार॥" },

    { "startSeconds": 56.57, "text": "॥ चौपाई ॥" },
    { "startSeconds": 56.57, "text": "जय हनुमान ज्ञान गुन सागर।" },
    { "startSeconds": 62.27, "text": "जय कपीस तिहुँ लोक उजागर॥ १॥" },
    { "startSeconds": 67.60, "text": "राम दूत अतुलित बल धामा।" },
    { "startSeconds": 72.95, "text": "अञ्जनि-पुत्र पवनसुत नामा॥ २॥" },

    { "startSeconds": 83.51, "text": "महाबीर बिक्रम बजरंगी।" },
    { "startSeconds": 89.13, "text": "कुमति निवार सुमति के संगी॥ ३॥" },
    { "startSeconds": 94.21, "text": "कञ्चन बरन बिराज सुबेसा।" },
    { "startSeconds": 99.56, "text": "कानन कुण्डल कुञ्चित केसा॥ ४॥" },

    { "startSeconds": 104.91, "text": "हाथ बज्र औ ध्वजा बिराजै।" },
    { "startSeconds": 110.14, "text": "काँधे मूँज जनेऊ साजै॥ ५॥" },
    { "startSeconds": 115.46, "text": "संकर सुवन केसरीनन्दन।" },
    { "startSeconds": 120.65, "text": "तेज प्रताप महा जग बन्दन॥ ६॥" },

    { "startSeconds": 131.16, "text": "विद्यावान गुनी अति चातुर।" },
    { "startSeconds": 136.62, "text": "राम काज करिबे को आतुर॥ ७॥" },
    { "startSeconds": 141.90, "text": "प्रभु चरित्र सुनिबे को रसिया।" },
    { "startSeconds": 147.21, "text": "राम लखन सीता मन बसिया॥ ८॥" },

    { "startSeconds": 152.52, "text": "सूक्ष्म रूप धरि सियहिं दिखावा।" },
    { "startSeconds": 157.77, "text": "बिकट रूप धरि लंक जरावा॥ ९॥" },
    { "startSeconds": 163.05, "text": "भीम रूप धरि असुर सँहारे।" },
    { "startSeconds": 168.33, "text": "रामचन्द्र के काज सँवारे॥ १०॥" },

    { "startSeconds": 178.62, "text": "लाय सञ्जीवन लखन जियाये।" },
    { "startSeconds": 184.25, "text": "श्री रघुबीर हरषि उर लाये॥ ११॥" },
    { "startSeconds": 189.53, "text": "रघुपति कीन्ही बहुत बड़ाई।" },
    { "startSeconds": 194.76, "text": "तुम मम प्रिय भरतहि सम भाई॥ १२॥" },

    { "startSeconds": 200.03, "text": "सहस बदन तुम्हरो जस गावैं।" },
    { "startSeconds": 205.20, "text": "अस कहि श्रीपति कण्ठ लगावैं॥ १३॥" },
    { "startSeconds": 210.52, "text": "सनकादिक ब्रह्मादि मुनीसा।" },
    { "startSeconds": 215.91, "text": "नारद-सारद सहित अहीसा॥ १४॥" },

    { "startSeconds": 226.26, "text": "जम कुबेर दिगपाल जहाँ ते।" },
    { "startSeconds": 231.82, "text": "कबि कोबिद कहि सके कहाँ ते॥ १५॥" },
    { "startSeconds": 237.12, "text": "तुम उपकार सुग्रीवहिं कीन्हा।" },
    { "startSeconds": 242.39, "text": "राम मिलाय राजपद दीन्हा॥ १६॥" },

    { "startSeconds": 247.57, "text": "तुम्हरो मन्त्र बिभीषन माना।" },
    { "startSeconds": 252.88, "text": "लंकेस्वर भए सब जग जाना॥ १७॥" },
    { "startSeconds": 258.30, "text": "जुग सहस्र जोजन पर भानू।" },
    { "startSeconds": 263.57, "text": "लील्यो ताहि मधुर फल जानू॥ १८॥" },

    { "startSeconds": 274.06, "text": "प्रभु मुद्रिका मेलि मुख माहीं।" },
    { "startSeconds": 279.65, "text": "जलधि लाँघि गये अचरज नाहीं॥ १९॥" },
    { "startSeconds": 284.87, "text": "दुर्गम काज जगत के जेते।" },
    { "startSeconds": 290.05, "text": "सुगम अनुग्रह तुम्हरे तेते॥ २०॥" },

    { "startSeconds": 295.34, "text": "राम दुआरे तुम रखवारे।" },
    { "startSeconds": 300.67, "text": "होत न आज्ञा बिनु पैसारे॥ २१॥" },
    { "startSeconds": 306.03, "text": "सब सुख लहैं तुम्हारी सरना।" },
    { "startSeconds": 311.26, "text": "तुम रक्षक काहू को डरना॥ २२॥" },

    { "startSeconds": 321.76, "text": "आपन तेज सम्हारो आपै।" },
    { "startSeconds": 327.28, "text": "तीनों लोक हाँक तें काँपै॥ २३॥" },
    { "startSeconds": 332.65, "text": "भूत पिसाच निकट नहिं आवै।" },
    { "startSeconds": 337.62, "text": "महाबीर जब नाम सुनावै॥ २४॥" },

    { "startSeconds": 343.08, "text": "नासै रोग हरै सब पीरा।" },
    { "startSeconds": 348.36, "text": "जपत निरन्तर हनुमत बीरा॥ २५॥" },
    { "startSeconds": 353.66, "text": "संकट तें हनुमान छुड़ावै।" },
    { "startSeconds": 359.08, "text": "मन क्रम बचन ध्यान जो लावै॥ २६॥" },

    { "startSeconds": 369.43, "text": "सब पर राम तपस्वी राजा।" },
    { "startSeconds": 374.98, "text": "तिनके काज सकल तुम साजा॥ २७॥" },
    { "startSeconds": 380.15, "text": "और मनोरथ जो कोई लावै।" },
    { "startSeconds": 385.31, "text": "सोई अमित जीवन फल पावै॥ २८॥" },

    { "startSeconds": 390.77, "text": "चारों जुग परताप तुम्हारा।" },
    { "startSeconds": 396.15, "text": "है परसिद्ध जगत उजियारा॥ २९॥" },
    { "startSeconds": 401.36, "text": "साधु-सन्त के तुम रखवारे।" },
    { "startSeconds": 406.74, "text": "असुर निकन्दन राम दुलारे॥ ३०॥" },

    { "startSeconds": 416.95, "text": "अष्टसिद्धि नव निधि के दाता।" },
    { "startSeconds": 422.37, "text": "अस बर दीन्ह जानकी माता॥ ३१॥" },
    { "startSeconds": 427.58, "text": "राम रसायन तुम्हरे पासा।" },
    { "startSeconds": 432.72, "text": "सदा रहो रघुपति के दासा॥ ३२॥" },

    { "startSeconds": 438.11, "text": "तुम्हरे भजन राम को पावै।" },
    { "startSeconds": 443.47, "text": "जनम-जनम के दुख बिसरावै॥ ३३॥" },
    { "startSeconds": 448.79, "text": "अन्त काल रघुबर पुर जाई।" },
    { "startSeconds": 454.02, "text": "जहाँ जन्म हरि-भक्त कहाई॥ ३४॥" },

    { "startSeconds": 464.23, "text": "और देवता चित्त न धरई।" },
    { "startSeconds": 469.73, "text": "हनुमत सेई सर्ब सुख करई॥ ३५॥" },
    { "startSeconds": 474.91, "text": "संकट कटै मिटै सब पीरा।" },
    { "startSeconds": 480.10, "text": "जो सुमिरै हनुमत बलबीरा॥ ३६॥" },

    { "startSeconds": 485.54, "text": "जय जय जय हनुमान गोसाईं।" },
    { "startSeconds": 490.69, "text": "कृपा करहु गुरुदेव की नाईं॥ ३७॥" },
    { "startSeconds": 496.05, "text": "जो सत बार पाठ कर कोई।" },
    { "startSeconds": 501.20, "text": "छूटहि बन्दि महा सुख होई॥ ३८॥" },

    { "startSeconds": 511.48, "text": "जो यह पढ़ै हनुमान चालीसा।" },
    { "startSeconds": 517.07, "text": "होय सिद्धि साखी गौरीसा॥ ३९॥" },
    { "startSeconds": 522.32, "text": "तुलसीदास सदा हरि चेरा।" },
    { "startSeconds": 527.38, "text": "कीजै नाथ हृदय मँह डेरा॥ ४०॥" },

    { "startSeconds": 540.93, "text": "॥ दोहा ॥" },
    { "startSeconds": 549.48, "text": "पवनतनय संकट हरन, मंगल मूरति रूप।" },
    { "startSeconds": 557.38, "text": "राम लखन सीता सहित, हृदय बसहु सुर भूप॥" }
  ]
}