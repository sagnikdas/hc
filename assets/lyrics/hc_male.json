{
  "title": "Hanuman Chalisa — Male Recitation",
  "totalDurationSeconds": 204,
  "lines": [
    {
      "startSeconds": 1.81,
      "text": "॥ दोहा ॥",
      "en": "|| Doha ||"
    },
    {
      "startSeconds": 1.81,
      "text": "श्रीगुरु चरन सरोज रज, निज मनु मुकुरु सुधारि।",
      "en": "Shri Guru Charan Saroj Raj, Nij Man Mukur Sudhari,"
    },
    {
      "startSeconds": 3.91,
      "text": "बरनउँ रघुबर बिमल जसु, जो दायकु फल चारि॥",
      "en": "Baranau Raghubar Bimal Jasu, Jo Dayaku Phal Chari."
    },
    {
      "startSeconds": 5.83,
      "text": "बुद्धिहीन तनु जानिके, सुमिरौं पवन-कुमार।",
      "en": "Buddhihin Tanu Jaanike, Sumiron Pawan Kumar,"
    },
    {
      "startSeconds": 7.88,
      "text": "बल बुद्धि बिद्या देहु मोहिं, हरहु कलेस बिकार॥",
      "en": "Bal Buddhi Vidya Dehu Mohi, Harahu Kales Bikar."
    },
    {
      "startSeconds": 10.2,
      "text": "॥ चौपाई ॥",
      "en": "|| Chaupai ||"
    },
    {
      "startSeconds": 12.16,
      "text": "जय हनुमान ज्ञान गुन सागर।",
      "en": "Jai Hanuman Gyan Gun Sagar,"
    },
    {
      "startSeconds": 14.3,
      "text": "जय कपीस तिहुँ लोक उजागर॥ १॥",
      "en": "Jai Kapees Tihu Lok Ujagar. (1)"
    },
    {
      "startSeconds": 16.3,
      "text": "राम दूत अतुलित बल धामा।",
      "en": "Ram Doot Atoolit Bal Dhama,"
    },
    {
      "startSeconds": 18.31,
      "text": "अञ्जनि-पुत्र पवनसुत नामा॥ २॥",
      "en": "Anjani Putra Pavanasoota Nama. (2)"
    },
    {
      "startSeconds": 22.28,
      "text": "महाबीर बिक्रम बजरंगी।",
      "en": "Mahabeer Bikram Bajrangi,"
    },
    {
      "startSeconds": 24.39,
      "text": "कुमति निवार सुमति के संगी॥ ३॥",
      "en": "Kumati Niwar Sumati Ke Sangi. (3)"
    },
    {
      "startSeconds": 26.3,
      "text": "कञ्चन बरन बिराज सुबेसा।",
      "en": "Kanchan Baran Biraj Subesa,"
    },
    {
      "startSeconds": 28.31,
      "text": "कानन कुण्डल कुञ्चित केसा॥ ४॥",
      "en": "Kanan Kundal Kunchit Kesa. (4)"
    },
    {
      "startSeconds": 30.32,
      "text": "हाथ बज्र औ ध्वजा बिराजै।",
      "en": "Haath Bajra Au Dhwaja Birajai,"
    },
    {
      "startSeconds": 32.28,
      "text": "काँधे मूँज जनेऊ साजै॥ ५॥",
      "en": "Kaandhe Moonj Janeu Sajai. (5)"
    },
    {
      "startSeconds": 34.28,
      "text": "संकर सुवन केसरीनन्दन।",
      "en": "Shankar Suvan Kesarinandan,"
    },
    {
      "startSeconds": 36.23,
      "text": "तेज प्रताप महा जग बन्दन॥ ६॥",
      "en": "Tej Pratap Maha Jag Bandan. (6)"
    },
    {
      "startSeconds": 40.18,
      "text": "विद्यावान गुनी अति चातुर।",
      "en": "Vidyavaan Guni Ati Chatur,"
    },
    {
      "startSeconds": 42.23,
      "text": "राम काज करिबे को आतुर॥ ७॥",
      "en": "Ram Kaaj Karibe Ko Atur. (7)"
    },
    {
      "startSeconds": 44.21,
      "text": "प्रभु चरित्र सुनिबे को रसिया।",
      "en": "Prabhu Charitra Sunibe Ko Rasiya,"
    },
    {
      "startSeconds": 46.21,
      "text": "राम लखन सीता मन बसिया॥ ८॥",
      "en": "Ram Lakhan Sita Man Basiya. (8)"
    },
    {
      "startSeconds": 48.2,
      "text": "सूक्ष्म रूप धरि सियहिं दिखावा।",
      "en": "Sukshma Roop Dhari Siyahi Dikhawa,"
    },
    {
      "startSeconds": 50.17,
      "text": "बिकट रूप धरि लंक जरावा॥ ९॥",
      "en": "Bikat Roop Dhari Lanka Jarawa. (9)"
    },
    {
      "startSeconds": 52.16,
      "text": "भीम रूप धरि असुर सँहारे।",
      "en": "Bheem Roop Dhari Asur Sanhare,"
    },
    {
      "startSeconds": 54.14,
      "text": "रामचन्द्र के काज सँवारे॥ १०॥",
      "en": "Ramchandra Ke Kaaj Sanware. (10)"
    },
    {
      "startSeconds": 58.01,
      "text": "लाय सञ्जीवन लखन जियाये।",
      "en": "Laay Sanjeevan Lakhan Jiyaye,"
    },
    {
      "startSeconds": 60.12,
      "text": "श्री रघुबीर हरषि उर लाये॥ ११॥",
      "en": "Shri Raghubeer Harashi Ur Laaye. (11)"
    },
    {
      "startSeconds": 62.1,
      "text": "रघुपति कीन्ही बहुत बड़ाई।",
      "en": "Raghupati Kinhi Bahut Badaai,"
    },
    {
      "startSeconds": 64.07,
      "text": "तुम मम प्रिय भरतहि सम भाई॥ १२॥",
      "en": "Tum Mam Priya Bharatahi Sam Bhai. (12)"
    },
    {
      "startSeconds": 66.05,
      "text": "सहस बदन तुम्हरो जस गावैं।",
      "en": "Sahas Badan Tumharo Jas Gavain,"
    },
    {
      "startSeconds": 67.99,
      "text": "अस कहि श्रीपति कण्ठ लगावैं॥ १३॥",
      "en": "As Kahi Shripati Kanth Lagavain. (13)"
    },
    {
      "startSeconds": 69.99,
      "text": "सनकादिक ब्रह्मादि मुनीसा।",
      "en": "Sankaadik Brahmadi Munisa,"
    },
    {
      "startSeconds": 72.01,
      "text": "नारद-सारद सहित अहीसा॥ १४॥",
      "en": "Narad Saarad Sahit Ahisa. (14)"
    },
    {
      "startSeconds": 75.9,
      "text": "जम कुबेर दिगपाल जहाँ ते।",
      "en": "Jam Kuber Digpal Jahan Te,"
    },
    {
      "startSeconds": 77.99,
      "text": "कबि कोबिद कहि सके कहाँ ते॥ १५॥",
      "en": "Kabi Kobid Kahi Sake Kahan Te. (15)"
    },
    {
      "startSeconds": 79.98,
      "text": "तुम उपकार सुग्रीवहिं कीन्हा।",
      "en": "Tum Upkar Sugreevahi Kinha,"
    },
    {
      "startSeconds": 81.96,
      "text": "राम मिलाय राजपद दीन्हा॥ १६॥",
      "en": "Ram Milaay Rajpad Dinha. (16)"
    },
    {
      "startSeconds": 83.91,
      "text": "तुम्हरो मन्त्र बिभीषन माना।",
      "en": "Tumharo Mantra Bibhishan Maana,"
    },
    {
      "startSeconds": 85.9,
      "text": "लंकेस्वर भए सब जग जाना॥ १७॥",
      "en": "Lankeshwar Bhaye Sab Jag Jaana. (17)"
    },
    {
      "startSeconds": 87.94,
      "text": "जुग सहस्र जोजन पर भानू।",
      "en": "Jug Sahastra Jojan Par Bhanu,"
    },
    {
      "startSeconds": 89.92,
      "text": "लील्यो ताहि मधुर फल जानू॥ १८॥",
      "en": "Lilyo Taahi Madhur Phal Jaanu. (18)"
    },
    {
      "startSeconds": 93.86,
      "text": "प्रभु मुद्रिका मेलि मुख माहीं।",
      "en": "Prabhu Mudrika Meli Mukh Mahi,"
    },
    {
      "startSeconds": 95.96,
      "text": "जलधि लाँघि गये अचरज नाहीं॥ १९॥",
      "en": "Jaladhi Laanghi Gaye Acharaj Nahi. (19)"
    },
    {
      "startSeconds": 97.92,
      "text": "दुर्गम काज जगत के जेते।",
      "en": "Durgam Kaaj Jagat Ke Jete,"
    },
    {
      "startSeconds": 99.86,
      "text": "सुगम अनुग्रह तुम्हरे तेते॥ २०॥",
      "en": "Sugam Anugraha Tumhare Tete. (20)"
    },
    {
      "startSeconds": 101.85,
      "text": "राम दुआरे तुम रखवारे।",
      "en": "Ram Duaare Tum Rakhwaare,"
    },
    {
      "startSeconds": 103.85,
      "text": "होत न आज्ञा बिनु पैसारे॥ २१॥",
      "en": "Hot Na Agya Binu Paisare. (21)"
    },
    {
      "startSeconds": 105.87,
      "text": "सब सुख लहैं तुम्हारी सरना।",
      "en": "Sab Sukh Lahe Tumhari Sarna,"
    },
    {
      "startSeconds": 107.83,
      "text": "तुम रक्षक काहू को डरना॥ २२॥",
      "en": "Tum Rakshak Kahu Ko Darna. (22)"
    },
    {
      "startSeconds": 111.77,
      "text": "आपन तेज सम्हारो आपै।",
      "en": "Aapan Tej Samharo Aapai,"
    },
    {
      "startSeconds": 113.85,
      "text": "तीनों लोक हाँक तें काँपै॥ २३॥",
      "en": "Teeno Lok Haank Te Kaampai. (23)"
    },
    {
      "startSeconds": 115.86,
      "text": "भूत पिसाच निकट नहिं आवै।",
      "en": "Bhoot Pisaach Nikat Nahi Aavai,"
    },
    {
      "startSeconds": 117.73,
      "text": "महाबीर जब नाम सुनावै॥ २४॥",
      "en": "Mahabeer Jab Naam Sunavai. (24)"
    },
    {
      "startSeconds": 119.78,
      "text": "नासै रोग हरै सब पीरा।",
      "en": "Naasai Rog Harai Sab Pira,"
    },
    {
      "startSeconds": 121.77,
      "text": "जपत निरन्तर हनुमत बीरा॥ २५॥",
      "en": "Japat Nirantar Hanumat Bira. (25)"
    },
    {
      "startSeconds": 123.76,
      "text": "संकट तें हनुमान छुड़ावै।",
      "en": "Sankat Te Hanuman Chhuravai,"
    },
    {
      "startSeconds": 125.79,
      "text": "मन क्रम बचन ध्यान जो लावै॥ २६॥",
      "en": "Man Kram Bachan Dhyan Jo Lavai. (26)"
    },
    {
      "startSeconds": 129.68,
      "text": "सब पर राम तपस्वी राजा।",
      "en": "Sab Par Ram Tapasvi Raja,"
    },
    {
      "startSeconds": 131.76,
      "text": "तिनके काज सकल तुम साजा॥ २७॥",
      "en": "Tinke Kaaj Sakal Tum Saaja. (27)"
    },
    {
      "startSeconds": 133.71,
      "text": "और मनोरथ जो कोई लावै।",
      "en": "Aur Manorath Jo Koi Lavai,"
    },
    {
      "startSeconds": 135.65,
      "text": "सोई अमित जीवन फल पावै॥ २८॥",
      "en": "Soi Amit Jeevan Phal Pavai. (28)"
    },
    {
      "startSeconds": 137.7,
      "text": "चारों जुग परताप तुम्हारा।",
      "en": "Charon Jug Partap Tumhara,"
    },
    {
      "startSeconds": 139.72,
      "text": "है परसिद्ध जगत उजियारा॥ २९॥",
      "en": "Hai Parsiddh Jagat Ujiyara. (29)"
    },
    {
      "startSeconds": 141.67,
      "text": "साधु-सन्त के तुम रखवारे।",
      "en": "Sadhu Sant Ke Tum Rakhware,"
    },
    {
      "startSeconds": 143.69,
      "text": "असुर निकन्दन राम दुलारे॥ ३०॥",
      "en": "Asur Nikandan Ram Dulare. (30)"
    },
    {
      "startSeconds": 147.53,
      "text": "अष्टसिद्धि नव निधि के दाता।",
      "en": "Ashta Siddhi Nava Nidhi Ke Daata,"
    },
    {
      "startSeconds": 149.57,
      "text": "अस बर दीन्ह जानकी माता॥ ३१॥",
      "en": "As Bar Dinh Janaki Mata. (31)"
    },
    {
      "startSeconds": 151.52,
      "text": "राम रसायन तुम्हरे पासा।",
      "en": "Ram Rasayan Tumhare Paasa,"
    },
    {
      "startSeconds": 153.45,
      "text": "सदा रहो रघुपति के दासा॥ ३२॥",
      "en": "Sada Raho Raghupati Ke Dasa. (32)"
    },
    {
      "startSeconds": 155.48,
      "text": "तुम्हरे भजन राम को पावै।",
      "en": "Tumhare Bhajan Ram Ko Pavai,"
    },
    {
      "startSeconds": 157.49,
      "text": "जनम-जनम के दुख बिसरावै॥ ३३॥",
      "en": "Janam Janam Ke Dukh Bisravai. (33)"
    },
    {
      "startSeconds": 159.49,
      "text": "अन्त काल रघुबर पुर जाई।",
      "en": "Ant Kaal Raghubar Pur Jaai,"
    },
    {
      "startSeconds": 161.45,
      "text": "जहाँ जन्म हरि-भक्त कहाई॥ ३४॥",
      "en": "Jahan Janam Hari Bhakt Kahai. (34)"
    },
    {
      "startSeconds": 165.29,
      "text": "और देवता चित्त न धरई।",
      "en": "Aur Devata Chitt Na Dharai,"
    },
    {
      "startSeconds": 167.36,
      "text": "हनुमत सेई सर्ब सुख करई॥ ३५॥",
      "en": "Hanumat Sei Sarb Sukh Karai. (35)"
    },
    {
      "startSeconds": 169.3,
      "text": "संकट कटै मिटै सब पीरा।",
      "en": "Sankat Katai Mitai Sab Pira,"
    },
    {
      "startSeconds": 171.25,
      "text": "जो सुमिरै हनुमत बलबीरा॥ ३६॥",
      "en": "Jo Sumirai Hanumat Balbira. (36)"
    },
    {
      "startSeconds": 173.29,
      "text": "जय जय जय हनुमान गोसाईं।",
      "en": "Jai Jai Jai Hanuman Gosain,"
    },
    {
      "startSeconds": 175.23,
      "text": "कृपा करहु गुरुदेव की नाईं॥ ३७॥",
      "en": "Kripa Karahu Gurudev Ki Naain. (37)"
    },
    {
      "startSeconds": 177.24,
      "text": "जो सत बार पाठ कर कोई।",
      "en": "Jo Sat Baar Path Kar Koi,"
    },
    {
      "startSeconds": 179.18,
      "text": "छूटहि बन्दि महा सुख होई॥ ३८॥",
      "en": "Chutahi Bandi Maha Sukh Hoi. (38)"
    },
    {
      "startSeconds": 183.04,
      "text": "जो यह पढ़ै हनुमान चालीसा।",
      "en": "Jo Yah Padhai Hanuman Chalisa,"
    },
    {
      "startSeconds": 185.14,
      "text": "होय सिद्धि साखी गौरीसा॥ ३९॥",
      "en": "Hoy Siddhi Sakhi Gaurisa. (39)"
    },
    {
      "startSeconds": 187.11,
      "text": "तुलसीदास सदा हरि चेरा।",
      "en": "Tulsidas Sada Hari Chera,"
    },
    {
      "startSeconds": 189.01,
      "text": "कीजै नाथ हृदय मँह डेरा॥ ४०॥",
      "en": "Kijai Nath Hriday Mah Dera. (40)"
    },
    {
      "startSeconds": 194.1,
      "text": "॥ दोहा ॥",
      "en": "|| Doha ||"
    },
    {
      "startSeconds": 197.31,
      "text": "पवनतनय संकट हरन, मंगल मूरति रूप।",
      "en": "Pavanataney Sankat Haran, Mangal Moorti Roop,"
    },
    {
      "startSeconds": 200.28,
      "text": "राम लखन सीता सहित, हृदय बसहु सुर भूप॥",
      "en": "Ram Lakhan Sita Sahit, Hriday Basahu Sur Bhoop."
    }
  ]
}
